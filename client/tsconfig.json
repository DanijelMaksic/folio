{
   "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "moduleResolution": "bundler",
      "jsx": "react-jsx",
      "strict": true,
      "noEmit": true,
      "skipLibCheck": true,
      "paths": {
         "@/*": ["./src/*"],
         "@server/*": ["../server/src/*"],
         "@shared": ["../shared/src/index.ts"]
      },
      "types": ["vite/client"]
   },
   "include": ["src"]
}

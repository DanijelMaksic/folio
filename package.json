{
   "name": "folio",
   "private": true,
   "workspaces": [
      "client",
      "server",
      "shared"
   ],
   "scripts": {
      "predev": "docker compose up -d",
      "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
      "dev:ci": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
      "preview": "vite preview",
      "test:unit": "vitest run --passWithNoTests",
      "test:e2e": "playwright test",
      "build-only": "vite build"
   },
   "devDependencies": {
      "@playwright/test": "^1.61.1",
      "@types/node": "^26.0.1",
      "concurrently": "^10.0.3",
      "playwright": "^1.61.1"
   },
   "engines": {
      "node": "^24.0.0",
      "npm": ">=11"
   },
   "overrides": {
      "esbuild": "^0.25.0",
      "shell-quote": "^1.8.5"
   }
}
